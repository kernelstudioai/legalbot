BOT_MODE=smoke
OPENWA_SESSION_ID=legalbot-smoke
# Optional Windows smoke override for a system Chrome install.
# When set, smoke startup passes both executablePath and useChrome=true to OpenWA.
# OPENWA_BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
OPENWA_STARTUP_MAX_ATTEMPTS=1
OPENWA_STARTUP_RETRY_DELAY_SECONDS=5
OPENWA_LIVENESS_INTERVAL_SECONDS=30
OPENWA_LIVENESS_FAILURE_THRESHOLD=3
OPENWA_RECOVERY_MODE=manual
OPENWA_RECOVERY_MAX_ATTEMPTS=0
OPENWA_RECOVERY_RETRY_DELAY_SECONDS=10
OPENWA_STATUS_SERVER_ENABLED=false
OPENWA_STATUS_SERVER_HOST=127.0.0.1
OPENWA_STATUS_SERVER_PORT=3001
DATABASE_URL=file:./data/legalbot.sqlite
DATABASE_MIGRATIONS_ENABLED=true
LAWYER_PHONE_E164=+15551234567
LOG_LEVEL=info
NODE_ENV=development
