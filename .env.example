# Minimum operator-specific runtime value for local direct and Docker runs.
LAWYER_PHONE_E164=+15551234567

# Transport selector. OpenWA remains legacy/dev-only. Cloud is the production direction.
# WHATSAPP_TRANSPORT=openwa

# Cloud runtime values are required only when WHATSAPP_TRANSPORT=cloud.
# WHATSAPP_CLOUD_API_VERSION=vXX.Y
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=1234567890
# WHATSAPP_CLOUD_VERIFY_TOKEN=replace-me
# WHATSAPP_CLOUD_ACCESS_TOKEN=replace-me
# WHATSAPP_CLOUD_APP_SECRET=replace-me
# WHATSAPP_CLOUD_WEBHOOK_HOST=0.0.0.0
# WHATSAPP_CLOUD_WEBHOOK_PORT=3002

# Optional local direct override when OpenWA cannot discover Chrome/Chromium.
# OPENWA_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# OPENWA_BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional direct-run overrides. Safe defaults are loaded by src/config/env.ts.
# NODE_ENV=production
# LOG_LEVEL=info
# BOT_MODE=smoke
# OPENWA_SESSION_ID=legalbot-smoke
# DATABASE_URL=file:./data/legalbot.sqlite
# DATABASE_MIGRATIONS_ENABLED=true
# BUSINESS_PERSISTENCE_ENABLED=true
# TECHNICAL_PERSISTENCE_ENABLED=true
# OPENWA_STATUS_SERVER_ENABLED=true
# OPENWA_STATUS_SERVER_HOST=127.0.0.1
# OPENWA_STATUS_SERVER_PORT=3001
