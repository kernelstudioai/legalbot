{
  "name": "legalbot-openwa-foundation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "business:backup": "node --experimental-strip-types src/app/businessBackup.ts",
    "business:check": "node --experimental-strip-types src/app/businessCheck.ts",
    "case:doctor": "node --experimental-strip-types src/app/caseDoctor.ts",
    "case:create-from-intake": "node --experimental-strip-types src/app/caseCreateFromIntake.ts",
    "db:migrate": "node --experimental-strip-types src/app/dbMigrate.ts",
    "db:status": "node --experimental-strip-types src/app/dbStatus.ts",
    "docker:build": "docker compose build",
    "docker:diagnose": "node --experimental-strip-types src/app/dockerDiagnose.ts",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs --tail=100 -f legalbot",
    "ops:post-start": "node --experimental-strip-types src/app/opsPostStart.ts",
    "ops:post-start:cloud": "node --experimental-strip-types src/app/opsPostStart.ts --transport cloud",
    "ops:preflight": "node --experimental-strip-types src/app/opsPreflight.ts",
    "ops:preflight:cloud": "node --experimental-strip-types src/app/opsPreflight.ts --transport cloud",
    "docker:status": "docker compose ps",
    "docker:up": "docker compose up -d",
    "intake:list-ready": "node --experimental-strip-types src/app/intakeListReady.ts",
    "smoke:openwa": "node --experimental-strip-types src/app/openwaSmoke.ts",
    "start:whatsapp-cloud": "node --experimental-strip-types src/app/whatsappCloudRuntime.ts",
    "runtime:cloud": "node --experimental-strip-types src/app/whatsappCloudRuntime.ts",
    "webhook:replay:cloud": "node --experimental-strip-types src/app/whatsappCloudWebhookReplay.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@open-wa/wa-automate": "^4.76.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "patch-package": "^8.0.1",
    "typescript": "latest",
    "vitest": "latest"
  }
}
