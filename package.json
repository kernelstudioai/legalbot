{
  "name": "legalbot-openwa-foundation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "case:doctor": "node --experimental-strip-types src/app/caseDoctor.ts",
    "case:create-from-intake": "node --experimental-strip-types src/app/caseCreateFromIntake.ts",
    "db:migrate": "node --experimental-strip-types src/app/dbMigrate.ts",
    "db:status": "node --experimental-strip-types src/app/dbStatus.ts",
    "smoke:openwa": "node --experimental-strip-types src/app/openwaSmoke.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@open-wa/wa-automate": "^4.76.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "patch-package": "^8.0.1",
    "typescript": "latest",
    "vitest": "latest"
  }
}
